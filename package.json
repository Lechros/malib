{
  "name": "malib",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": {
    "packages": [
      "packages/*"
    ]
  },
  "scripts": {
    "build": "turbo run build",
    "lint": "prettier --check . && turbo run lint",
    "check": "turbo run check",
    "test": "turbo run test",
    "format": "prettier . --write",
    "precommit": "turbo run lint check test"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "prettier": "^3.8.1",
    "turbo": "^2.8.14",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@9.15.9"
}
