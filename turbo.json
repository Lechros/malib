{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "check": {
      "dependsOn": ["typecheck:lib", "typecheck:test"]
    },
    "typecheck:lib": {
      "dependsOn": ["^typecheck:lib"]
    },
    "typecheck:test": {
      "dependsOn": ["^typecheck:lib"]
    },
    "test": {}
  }
}
